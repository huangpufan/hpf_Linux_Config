{
  "categories": [
    {
      "id": "presets",
      "name": "预设组合",
      "tools": [
        {
          "id": "preset-bootstrap",
          "name": "环境引导与 GitHub SSH",
          "description": "安装前置配置：目录、bashrc、git/gh、GitHub 认证、SSH key 上传",
          "script": "presets/bootstrap.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "test -d ~/workspace && grep -q 'Bashrc Already Set' ~/.bashrc && command -v gh && gh auth status --hostname github.com >/dev/null 2>&1 && test -f ~/.ssh/id_ed25519.pub && gh config get git_protocol --host github.com 2>/dev/null | grep -qx ssh",
          "timeout": 3600
        },
        {
          "id": "preset-minimal",
          "name": "最小工具集",
          "description": "基础命令行工具：git、gh、tmux、htop、bat、fzf、zoxide",
          "script": "presets/minimal.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "command -v gh && command -v fzf && command -v zoxide",
          "timeout": 3600
        },
        {
          "id": "preset-dev-cli",
          "name": "CLI 开发工具集",
          "description": "现代 CLI 工具：lazygit、eza、broot、fkill 等",
          "script": "presets/dev-cli.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "command -v lazygit && command -v eza",
          "timeout": 3600
        },
        {
          "id": "preset-dev-full",
          "name": "完整开发环境",
          "description": "CLI + 编译器 + 调试工具 + 高级文件管理",
          "script": "presets/dev-full.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "command -v yazi && pipx list 2>/dev/null | grep -q gdbgui",
          "timeout": 3600
        },
        {
          "id": "preset-all-tools",
          "name": "全部工具",
          "description": "运行当前仓库维护的全部预设工具脚本",
          "script": "presets/all-tools.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "command -v bandwhich && command -v yazi",
          "timeout": 3600
        }
      ]
    },
    {
      "id": "setup",
      "name": "系统配置",
      "tools": [
        {
          "id": "bashrc",
          "name": "Bashrc 初始化",
          "description": "配置 .bashrc 基础环境变量",
          "script": "basic/bashrc-init.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "grep -q 'Bashrc Already Set' ~/.bashrc",
          "timeout": 1800
        },
        {
          "id": "folder-create",
          "name": "目录结构创建",
          "description": "创建标准工作目录结构",
          "script": "basic/folder-create.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "test -d ~/workspace || test -d ~/project",
          "timeout": 1800
        },
        {
          "id": "git-identity",
          "name": "Git 身份配置",
          "description": "配置 git user.name 与 user.email；通过参数或环境变量提供值",
          "script": "setup/git-identity.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "git config --global user.name >/dev/null 2>&1 && git config --global user.email >/dev/null 2>&1",
          "timeout": 1800
        },
        {
          "id": "github-auth",
          "name": "GitHub CLI 认证",
          "description": "使用 gh 登录 GitHub，并默认配置为 HTTPS + gh credential helper",
          "script": "setup/github-auth.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "gh auth status --hostname github.com >/dev/null 2>&1 && gh config get git_protocol --host github.com 2>/dev/null | grep -Eq '^(https|ssh)$'",
          "timeout": 1800
        },
        {
          "id": "github-ssh",
          "name": "GitHub SSH 可选增强",
          "description": "使用 gh 生成并上传 SSH key，然后把 GitHub git protocol 切到 ssh",
          "script": "setup/github-ssh.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "test -f ~/.ssh/id_ed25519.pub && gh auth status --hostname github.com >/dev/null 2>&1 && gh config get git_protocol --host github.com 2>/dev/null | grep -qx ssh",
          "timeout": 1800
        },
        {
          "id": "source-change",
          "name": "Ubuntu 换源",
          "description": "更换 apt 软件源为国内镜像",
          "script": "basic/ubuntu-source-change.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": ". /etc/os-release && if [ \"$VERSION_ID\" = \"24.04\" ]; then grep -q 'mirrors.aliyun.com/ubuntu' /etc/apt/sources.list.d/ubuntu.sources; else grep -q 'mirrors.aliyun.com/ubuntu' /etc/apt/sources.list; fi",
          "timeout": 1800
        },
        {
          "id": "npm-registry",
          "name": "NPM 镜像配置",
          "description": "配置 npm 使用国内镜像源",
          "script": "setup/npm-registry.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "npm config get registry 2>/dev/null | grep -q npmmirror",
          "timeout": 1800
        },
        {
          "id": "cargo-registry",
          "name": "Cargo 镜像配置",
          "description": "配置 cargo 使用国内镜像源",
          "script": "setup/cargo-registry.sh",
          "requires_sudo": false,
          "requires_ssh": false,
          "check_cmd": "test -f ~/.cargo/config.toml || test -L ~/.cargo/config.toml",
          "timeout": 1800
        },
        {
          "id": "configs",
          "name": "Dotfiles 配置",
          "description": "Tmux、Herdr 等配置文件",
          "script": "basic/config-install.sh",
          "requires_sudo": true,
          "requires_ssh": false,
          "check_cmd": "test -L ~/.tmux.conf && test -L ~/.config/herdr/config.toml",
          "timeout": 1800
        }
      ]
    },
